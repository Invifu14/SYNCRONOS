{
  "expo": {
    "name": "syncronos-app",
    "slug": "syncronos-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "SYNCRONOS necesita acceso a tus fotos para que subas imagenes reales a tu perfil.",
          "cameraPermission": "SYNCRONOS necesita usar tu camara para que tomes fotos reales desde la app.",
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "messages"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSUserNotificationUsageDescription": "SYNCRONOS usa notificaciones para avisarte de mensajes y matches nuevos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "POST_NOTIFICATIONS",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
